# Конфиг локального воркера авторизации (auth_worker.py).
# Скопируй в .env.worker и заполни. Воркер запускается на ДОМАШНЕМ ПК.

# Публичный URL твоего контейнера-бота на DockHost (тот, что отдаёт /health).
RELAY_URL=https://твой-контейнер.dockhost.ru

# Секрет — ДОЛЖЕН совпадать с AUTH_RELAY_TOKEN в .env.bot на сервере.
# Сгенерировать: python -c "import secrets; print(secrets.token_urlsafe(32))"
RELAY_TOKEN=вставь_тот_же_секрет

# Период опроса сервера в секундах (необязательно).
RELAY_POLL=2

# Прокси для запроса кода — в отдельном файле proxies.txt (см. proxies.txt.example).
# По одному на строку, воркер ротирует. Резидентные/мобильные РФ-прокси снимают
# лимит «всё с одного IP» и дают масштаб. Нужен пакет: pip install "python-socks[asyncio]"
