# Общий бот-доставщик — ОДИН на всех. Скопируй этот файл в .env.bot и заполни.
# Он принимает перехваты у всех аккаунтов и шлёт их владельцу каждого аккаунта
# (OWNER_ID в .env / .env.friend), поэтому у разных людей — только свои уведомления.

# --- Токен общего бота от @BotFather ---
BOT_TOKEN=123456789:AA...

# --- api_id / api_hash для бота (нужны Telethon) ---
# Подойдут любые валидные — можно те же, что у твоего аккаунта в .env.
API_ID=123456
API_HASH=вставь_сюда_api_hash

# --- id админа (кому доступна админ-панель добавления/удаления аккаунтов) ---
# Узнать свой id: напиши боту /start. Пусто/0 = админ-панель выключена.
ADMIN_ID=0

# --- Вход по КОДУ через локального воркера (auth_relay) ---
# Бот на хостинге (IP дата-центра) не получает код входа — Telegram его не шлёт.
# Поэтому код запрашивает воркер с домашнего ПК (auth_worker.py), а сюда отдаёт
# готовую сессию. Этот секрет должен совпадать с RELAY_TOKEN в .env.worker.
# Сгенерировать: python -c "import secrets; print(secrets.token_urlsafe(32))"
# Пусто = вход по коду выключен (останется только QR).
AUTH_RELAY_TOKEN=
# Порт HTTP-relay внутри контейнера (наружу пробрось его публичным URL DockHost).
AUTH_RELAY_PORT=8080
