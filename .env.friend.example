# Аккаунт ДРУГА. Скопируй этот файл в .env.friend и заполни ЕГО значениями.
# Первый вход в этот аккаунт:  python main.py friend
# Бот общий (см. .env.bot) — отдельный токен другу больше не нужен.

# Ключи друга с https://my.telegram.org (его собственные)
API_ID=123456
API_HASH=api_hash_друга

# Telegram user id друга (кому слать перехваты с ЕГО аккаунта).
# Узнаём: друг пишет общему боту /start.
OWNER_ID=0

# Настройки
CACHE_MEDIA=true
RETENTION_DAYS=7
