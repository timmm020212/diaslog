# Профиль ДРУГА. Скопируй этот файл в .env.friend и заполни ЕГО значениями.
# Запуск этого профиля:  python main.py friend

# Ключи друга с https://my.telegram.org (можно его собственные)
API_ID=123456
API_HASH=api_hash_друга

# Токен ОТДЕЛЬНОГО бота друга от @BotFather (свой, не твой)
BOT_TOKEN=123456789:AA...

# Telegram user id друга (узнаем: друг пишет своему боту /start)
OWNER_ID=0

# Настройки
CACHE_MEDIA=true
RETENTION_DAYS=7
