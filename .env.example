# Скопируй этот файл в .env и заполни своими значениями.

# --- Ключи с https://my.telegram.org (API development tools) ---
API_ID=123456
API_HASH=вставь_сюда_api_hash

# --- Токен бота от @BotFather ---
BOT_TOKEN=123456789:AA...

# --- Твой Telegram user id (получателя уведомлений) ---
# Узнать можно так: напиши своему боту /start — он пришлёт твой ID.
OWNER_ID=0

# --- Настройки (можно не трогать) ---
# Скачивать ли входящие медиа, чтобы можно было прислать удалённые фото/видео (true/false)
CACHE_MEDIA=true
# Сколько дней хранить кэш сообщений и медиа
RETENTION_DAYS=7
