# Аккаунт, за которым следим (аккаунт по умолчанию).
# Скопируй этот файл в .env и заполни своими значениями.
# Доставку делает ОДИН общий бот — его токен в .env.bot (см. .env.bot.example).

# --- Ключи с https://my.telegram.org (API development tools) ---
API_ID=123456
API_HASH=вставь_сюда_api_hash

# --- Твой Telegram user id (кому слать перехваты с ЭТОГО аккаунта) ---
# Узнать можно так: напиши общему боту /start — он пришлёт твой ID.
OWNER_ID=0

# --- Настройки (можно не трогать) ---
# Скачивать ли входящие медиа, чтобы можно было прислать удалённые фото/видео (true/false)
CACHE_MEDIA=true
# Сколько дней хранить кэш сообщений и медиа
RETENTION_DAYS=7
